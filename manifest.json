{
  "manifest_version": 3,
  "name": "Tempo",
  "version": "0.1.0",
  "description": "Transitions you from chaotic context switching into focused work by pre-loading the workspace for upcoming calendar events.",
  "permissions": [
    "identity",
    "tabs",
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://www.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "659687020686-62d45atemo42v8smoscphaknioq1kai2.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/calendar.readonly"
    ]
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-grey-16.png",
      "32": "icons/icon-grey-32.png",
      "48": "icons/icon-grey-48.png",
      "128": "icons/icon-grey-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-grey-16.png",
    "32": "icons/icon-grey-32.png",
    "48": "icons/icon-grey-48.png",
    "128": "icons/icon-grey-128.png"
  }
}
